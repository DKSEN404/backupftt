<div class="crw-step-stats">
  <div class="crw-budget-header">
    <span class="crw-label">{{localize "crw.stats.title"}}</span>
    <div>
      <span class="crw-budget-value">{{remaining}}</span>
      <span class="crw-budget-label"> / {{totalPoints}} {{localize "crw.stats.remaining"}}</span>
    </div>
  </div>
  <div class="crw-budget-bar">
    <div class="crw-budget-fill" style="width: {{spentPercent}}%"></div>
  </div>

  <table class="crw-stat-table crw-stat-table--pointbuy">
    <tbody>
      {{#each statRows}}
      <tr>
        <td class="crw-stat-label">{{abbr}}</td>
        <td class="crw-stat-name">{{fullName}}</td>
        <td class="crw-stat-btn-cell"><button type="button" class="crw-stat-btn" data-action="statDec" data-stat="{{key}}">−</button></td>
        <td class="crw-stat-value">{{value}}</td>
        <td class="crw-stat-btn-cell"><button type="button" class="crw-stat-btn" data-action="statInc" data-stat="{{key}}">+</button></td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <div class="crw-hint">{{hint}}</div>
</div>
