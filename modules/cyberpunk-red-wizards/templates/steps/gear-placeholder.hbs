<div class="crw-step-gear crw-gear-placeholder">
  <h3 class="crw-section-title">{{localize "crw.gear.placeholderTitle"}}</h3>
  <div class="crw-gear-placeholder-box">
    <i class="fas fa-shopping-cart crw-gear-placeholder-icon"></i>
    <p>{{localize "crw.gear.placeholderDesc"}}</p>
    <div class="crw-budget-choice">
      <select class="crw-gear-select crw-input" name="startingBudget">
        <option value="2550" {{#if (eq startingBudget 2550)}}selected{{/if}}>{{localize "crw.gear.budget2550"}}</option>
        <option value="3350" {{#if (eq startingBudget 3350)}}selected{{/if}}>{{localize "crw.gear.budget3350"}}</option>
      </select>
    </div>
    <p class="crw-gear-fashion-note">{{localize "crw.gear.fashionNote"}}</p>
  </div>
</div>
