<div class="crw-step-skills">
  <div class="crw-skills-sticky-header">
    <div class="crw-budget-header">
      <span class="crw-label">{{localize "crw.skills.title"}}</span>
      <div>
        <span class="crw-budget-value">{{remaining}}</span>
        <span class="crw-budget-label"> / {{totalPoints}} {{localize "crw.skills.remaining"}}</span>
      </div>
    </div>
    <div class="crw-budget-bar">
      <div class="crw-budget-fill" style="width: {{spentPercent}}%"></div>
    </div>
  </div>

  <div class="crw-filter-group">
    <input type="text" class="crw-input crw-skill-filter" placeholder="{{localize "crw.skills.filter"}}">
  </div>

  <div class="crw-skill-categories">
    {{#each categories}}
    <div class="crw-skill-category" data-category="{{id}}">
      <h4 class="crw-category-title">{{label}}</h4>
      {{#each skills}}
      {{> "modules/cyberpunk-red-wizards/templates/partials/skill-row.hbs" editable=true}}
      {{/each}}
    </div>
    {{/each}}
  </div>

  <div class="crw-hint">{{hint}}</div>
</div>
