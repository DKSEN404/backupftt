<div class="crw-step-skills">
  <h3 class="crw-section-title">{{localize "crw.skills.fixedTitle"}}</h3>
  <p class="crw-section-subtitle">{{localize "crw.skills.fixedHint"}}</p>

  <div class="crw-skills-fixed-grid">
    {{#each skills}}
    <div class="crw-skill-fixed-item">
      <span class="crw-skill-name">{{name}}</span>
      <span class="crw-skill-level-badge">{{level}}</span>
    </div>
    {{/each}}
  </div>
</div>
