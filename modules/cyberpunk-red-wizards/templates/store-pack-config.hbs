<form>
  <p class="notes">{{localize "crw.store.settings.excludedPacksHint"}}</p>

  <h3>{{localize "crw.store.settings.packGroups"}}</h3>
  {{#each groups}}
  <div class="form-group">
    <label>{{this.label}}</label>
    <input type="checkbox" name="{{this.key}}" {{#if this.excluded}}checked{{/if}}>
  </div>
  {{/each}}

  {{#if hasDlc}}
  <h3>{{localize "crw.store.settings.packDlc"}}</h3>
  {{#each dlcPacks}}
  <div class="form-group">
    <label>{{this.label}}</label>
    <input type="checkbox" name="{{this.id}}" {{#if this.excluded}}checked{{/if}}>
  </div>
  {{/each}}
  {{/if}}

  <button type="submit"><i class="fas fa-save"></i> {{localize "crw.store.settings.savePackConfig"}}</button>
</form>
